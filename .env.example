APP_NAME=Vinmec AI API
APP_ENV=development
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_MOCK_LLM=false

# Security
AUTH_ENABLED=false
AUTH_API_KEY=change-me
RATE_LIMIT_PER_MINUTE=30

# Cost guard
MAX_MESSAGE_CHARS=2000
MAX_HISTORY_MESSAGES=30
MAX_TOTAL_CHARS=16000

